# ============================================================
# Environment variables for the Ashes of Prometheus dashboard
# ============================================================
#
# This is a TEMPLATE file. It is committed to git on purpose so future
# collaborators know what variables the app needs.
#
# To use locally:
#   1. Copy this file to `.env.local` (which IS gitignored — see .gitignore).
#   2. Fill in real values from the Supabase dashboard.
#
# For Vercel deployments, do NOT use this file. Instead, set the values
# directly in: Vercel dashboard → your project → Settings → Environment
# Variables. That's the only place real secrets should ever live.
#
# Find these values at:
#   https://supabase.com/dashboard → your project → Settings → API
#

# ---- Browser-safe (exposed to the client by design) ----

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key-here

# ---- Server-side only (NEVER expose, NEVER prefix with NEXT_PUBLIC_) ----

# The service_role key bypasses Row Level Security and can do anything to
# your database. Treat it like a password. Only set it in Vercel's env var
# UI; never paste it into chat, never commit a real value to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
